# World Labs Platform API (server-side only — used by Vite dev proxy).
# Get a key: https://platform.worldlabs.ai/api-keys
# Never use VITE_* for this; never commit real keys.
WORLDLABS_API_KEY=

# Optional: HTTPS origin hosting /models/... (same paths as repo). Needed on Vercel if you use
# tours without VITE_GOOGLE_MAPS_API_KEY (local glTF fallback). Omit trailing slash.
# VITE_MODEL_CDN_BASE=
